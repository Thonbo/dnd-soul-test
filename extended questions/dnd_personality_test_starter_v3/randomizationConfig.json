{
  "version": 3,
  "defaultMode": "fixed_target",
  "defaultQuestionCount": 50,
  "questionPoolSize": 400,
  "supportedModes": [
    "fixed_target",
    "adaptive_confidence"
  ],
  "supportedQuestionCount": {
    "absoluteMin": 5,
    "recommendedMin": 24,
    "recommendedDefault": 50,
    "recommendedMax": 120,
    "absoluteMax": 400
  },
  "categoryWeights": {
    "identity": 0.2,
    "power": 0.2,
    "combat": 0.2,
    "social": 0.2,
    "aesthetic": 0.2
  },
  "quotaStrategy": {
    "method": "largest_remainder_with_seed_rotated_remainders",
    "minimumPerCategoryWhenPossible": 1,
    "seedAffectsRemainderPriority": true,
    "notes": [
      "Convert targetCount * categoryWeight into raw quotas.",
      "Take the floor for each category.",
      "Distribute the remaining slots by fractional remainder.",
      "Rotate which categories receive remainder slots using the session seed so the same categories are not always favored when counts do not divide evenly."
    ]
  },
  "selectionStages": [
    "1. Resolve target count or adaptive bounds.",
    "2. Allocate category quotas proportionally.",
    "3. Seed-shuffle questions inside each category.",
    "4. Pull an initial balanced set.",
    "5. Validate trait coverage and duplicate similarity.",
    "6. Swap a small number of questions if coverage is skewed.",
    "7. Shuffle final display order while respecting max category streak rules."
  ],
  "presentationRules": {
    "maxConsecutiveQuestionsFromSameCategory": 2,
    "avoidImmediateNearDuplicateWording": true,
    "preserveSeedForResume": true
  },
  "coverageValidation": {
    "enabled": true,
    "targetDistinctTraitsFormula": "min(30, max(12, round(targetCount * 0.60)))",
    "minimumWeightTouchesPerCoreTraitCluster": {
      "personality": 4,
      "social_identity": 3,
      "power_source": 3,
      "playstyle": 4
    },
    "maxSingleTraitShareOfTotalTouches": 0.14,
    "rebalanceSwapLimit": 6
  },
  "adaptiveMode": {
    "enabled": true,
    "minQuestions": 24,
    "softTarget": 40,
    "maxQuestions": 80,
    "confidenceThreshold": 0.82,
    "stabilityThreshold": 0.78,
    "stopConditions": [
      "Stop if top build confidence >= confidenceThreshold and trait stability >= stabilityThreshold after minQuestions.",
      "Otherwise continue asking targeted follow-up questions until thresholds are met or maxQuestions is reached.",
      "If the top two builds remain very close, prefer class-disambiguation questions over generic filler questions."
    ],
    "uncertaintySignals": [
      "small margin between top two or top three builds",
      "high variance in opposed trait pairs like order/chaos or duty/freedom",
      "low exposure for a relevant trait cluster",
      "subclass split uncertainty inside the same class"
    ],
    "followUpSelectionStrategy": "target_underrepresented_traits_then_target_top_build_conflicts"
  },
